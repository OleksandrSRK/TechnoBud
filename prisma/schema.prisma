generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model address {
  id         Int      @id @default(autoincrement())
  label      String?
  country    String   @default("Ukraine")
  city       String
  street     String
  house      String
  apartment  String?
  postalCode String?
  isDefault  Boolean  @default(false)
  userId     Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  user       user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Address_userId_fkey")
  order      order[]

  @@index([userId], map: "Address_userId_idx")
}

model brand {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique(map: "Brand_slug_key")
  logoUrl     String?
  description String?   @db.Text
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  websiteUrl  String?
  product     product[]

  @@index([slug], map: "Brand_slug_idx")
}

model cart {
  id        Int         @id @default(autoincrement())
  status    cart_status @default(ACTIVE)
  sessionId String?     @unique(map: "Cart_sessionId_key")
  userId    Int?        @unique(map: "Cart_userId_key")
  createdAt DateTime    @default(now())
  updatedAt DateTime
  user      user?       @relation(fields: [userId], references: [id], map: "Cart_userId_fkey")
  cartitem  cartitem[]

  @@index([sessionId], map: "Cart_sessionId_idx")
  @@index([status], map: "Cart_status_idx")
}

model cartitem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  cartId    Int
  productId Int
  createdAt DateTime @default(now())
  updatedAt DateTime
  cart      cart     @relation(fields: [cartId], references: [id], onDelete: Cascade, map: "CartItem_cartId_fkey")
  product   product  @relation(fields: [productId], references: [id], map: "CartItem_productId_fkey")

  @@unique([cartId, productId], map: "CartItem_cartId_productId_key")
  @@index([cartId], map: "CartItem_cartId_idx")
  @@index([productId], map: "CartItem_productId_idx")
}

model category {
  id             Int        @id @default(autoincrement())
  name           String
  slug           String     @unique(map: "Category_slug_key")
  description    String?    @db.Text
  imageUrl       String?
  isActive       Boolean    @default(true)
  parentId       Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime
  category       category?  @relation("categoryTocategory", fields: [parentId], references: [id], map: "Category_parentId_fkey")
  other_category category[] @relation("categoryTocategory")
  product        product[]

  @@index([parentId], map: "Category_parentId_idx")
  @@index([slug], map: "Category_slug_idx")
}

model inventorymovement {
  id        Int                    @id @default(autoincrement())
  type      inventorymovement_type
  quantity  Int
  note      String?                @db.Text
  productId Int
  createdAt DateTime               @default(now())
  product   product                @relation(fields: [productId], references: [id], onDelete: Cascade, map: "InventoryMovement_productId_fkey")

  @@index([createdAt], map: "InventoryMovement_createdAt_idx")
  @@index([productId], map: "InventoryMovement_productId_idx")
  @@index([type], map: "InventoryMovement_type_idx")
}

model order {
  id              Int          @id @default(autoincrement())
  orderNumber     String       @unique(map: "Order_orderNumber_key")
  status          order_status @default(PENDING)
  customerName    String
  customerPhone   String
  customerEmail   String
  shippingAddress String       @db.Text
  subtotal        Decimal      @db.Decimal(10, 2)
  discountAmount  Decimal      @default(0.00) @db.Decimal(10, 2)
  shippingAmount  Decimal      @default(0.00) @db.Decimal(10, 2)
  totalAmount     Decimal      @db.Decimal(10, 2)
  notes           String?      @db.Text
  userId          Int?
  addressId       Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime
  address         address?     @relation(fields: [addressId], references: [id], map: "Order_addressId_fkey")
  user            user?        @relation(fields: [userId], references: [id], map: "Order_userId_fkey")
  orderitem       orderitem[]

  @@index([addressId], map: "Order_addressId_fkey")
  @@index([createdAt], map: "Order_createdAt_idx")
  @@index([status], map: "Order_status_idx")
  @@index([userId], map: "Order_userId_idx")
}

model orderitem {
  id                  Int      @id @default(autoincrement())
  quantity            Int      @default(1)
  unitPrice           Decimal  @db.Decimal(10, 2)
  totalPrice          Decimal  @db.Decimal(10, 2)
  orderId             Int
  productId           Int?
  productNameSnapshot String
  brandNameSnapshot   String?
  skuSnapshot         String?
  order               order    @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "OrderItem_orderId_fkey")
  product             product? @relation(fields: [productId], references: [id], map: "OrderItem_productId_fkey")

  @@index([orderId], map: "OrderItem_orderId_idx")
  @@index([productId], map: "OrderItem_productId_idx")
}

model product {
  id                   Int                    @id @default(autoincrement())
  name                 String
  price                Decimal                @db.Decimal(10, 2)
  currency             String                 @default("UAH")
  description          String                 @db.Text
  stock                Int                    @default(0)
  rating               Float                  @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  brandId              Int
  categoryId           Int
  color                String?
  energyClass          String?
  isActive             Boolean                @default(true)
  isFeatured           Boolean                @default(false)
  material             String?
  oldPrice             Decimal?               @db.Decimal(10, 2)
  powerW               Int?
  reservedStock        Int                    @default(0)
  reviewCount          Int                    @default(0)
  shortDescription     String?                @db.Text
  sku                  String                 @unique(map: "Product_sku_key")
  slug                 String                 @unique(map: "Product_slug_key")
  warrantyMonths       Int?
  weightKg             Decimal?               @db.Decimal(8, 2)
  cartitem             cartitem[]
  inventorymovement    inventorymovement[]
  orderitem            orderitem[]
  brand                brand                  @relation(fields: [brandId], references: [id], map: "Product_brandId_fkey")
  category             category               @relation(fields: [categoryId], references: [id], map: "Product_categoryId_fkey")
  productimage         productimage[]
  productspecification productspecification[]
  review               review[]
  wishlistitem         wishlistitem[]

  @@index([brandId], map: "Product_brandId_idx")
  @@index([categoryId], map: "Product_categoryId_idx")
  @@index([createdAt], map: "Product_createdAt_idx")
  @@index([isActive], map: "Product_isActive_idx")
  @@index([isFeatured], map: "Product_isFeatured_idx")
  @@index([price], map: "Product_price_idx")
}

model productimage {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isMain    Boolean  @default(false)
  productId Int
  createdAt DateTime @default(now())
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "ProductImage_productId_fkey")

  @@index([productId], map: "ProductImage_productId_idx")
  @@index([sortOrder], map: "ProductImage_sortOrder_idx")
}

model productspecification {
  id            Int     @id @default(autoincrement())
  name          String
  value         String
  unit          String?
  sortOrder     Int     @default(0)
  isHighlighted Boolean @default(false)
  productId     Int
  product       product @relation(fields: [productId], references: [id], onDelete: Cascade, map: "ProductSpecification_productId_fkey")

  @@index([name], map: "ProductSpecification_name_idx")
  @@index([productId], map: "ProductSpecification_productId_idx")
}

model review {
  id           Int      @id @default(autoincrement())
  rating       Int
  title        String?
  comment      String   @db.Text
  isApproved   Boolean  @default(false)
  userId       Int
  productId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  parentId     Int?
  review       review?  @relation("reviewToreview", fields: [parentId], references: [id], onDelete: Cascade, map: "Review_parentId_fkey")
  other_review review[] @relation("reviewToreview")
  product      product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "Review_productId_fkey")
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Review_userId_fkey")

  @@index([parentId], map: "Review_parentId_fkey")
  @@index([productId], map: "Review_productId_idx")
  @@index([rating], map: "Review_rating_idx")
  @@index([userId], map: "Review_userId_idx")
}

model user {
  id           Int       @id @default(autoincrement())
  email        String    @unique(map: "User_email_key")
  passwordHash String
  fullName     String
  phone        String?   @unique(map: "User_phone_key")
  role         user_role @default(CUSTOMER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  address      address[]
  cart         cart?
  order        order[]
  review       review[]
  wishlist     wishlist?

  @@index([email], map: "User_email_idx")
  @@index([phone], map: "User_phone_idx")
  @@index([role], map: "User_role_idx")
}

model wishlist {
  id           Int            @id @default(autoincrement())
  userId       Int            @unique(map: "Wishlist_userId_key")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  user         user           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Wishlist_userId_fkey")
  wishlistitem wishlistitem[]
}

model wishlistitem {
  id         Int      @id @default(autoincrement())
  wishlistId Int
  productId  Int
  createdAt  DateTime @default(now())
  product    product  @relation(fields: [productId], references: [id], map: "WishlistItem_productId_fkey")
  wishlist   wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade, map: "WishlistItem_wishlistId_fkey")

  @@unique([wishlistId, productId], map: "WishlistItem_wishlistId_productId_key")
  @@index([productId], map: "WishlistItem_productId_idx")
  @@index([wishlistId], map: "WishlistItem_wishlistId_idx")
}

enum cart_status {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum inventorymovement_type {
  IN
  OUT
  RESERVE
  RELEASE
  ADJUSTMENT
}

enum order_status {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
}

enum user_role {
  CUSTOMER
  ADMIN
}
